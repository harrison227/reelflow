NODE_ENV=development

# Postgres — local dev points at the docker-compose Postgres
DATABASE_URL=postgres://reelflow:reelflow@localhost:5432/reelflow

# Auth — shared-password gate. AUTH_SECRET signs the session cookie.
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
# The single shared password that unlocks the workspace.
SITE_PASSWORD=

# Object storage — S3-compatible. Local dev uses MinIO from docker-compose.
B2_ENDPOINT=http://localhost:9000
B2_REGION=auto
B2_BUCKET=reelflow-dev
B2_ACCESS_KEY_ID=minioadmin
B2_SECRET_ACCESS_KEY=minioadmin

# Logging
LOG_LEVEL=debug
