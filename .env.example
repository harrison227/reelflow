NODE_ENV=development

# Postgres — local dev points at docker-compose Postgres
DATABASE_URL=postgres://reelflow:reelflow@localhost:5432/reelflow

# Auth.js — generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Email — Resend powers both magic-link auth and notification emails
RESEND_API_KEY=
EMAIL_FROM=onboarding@example.com

# Object storage — S3-compatible. Local dev uses MinIO from docker-compose.
B2_ENDPOINT=http://localhost:9000
B2_REGION=auto
B2_BUCKET=reelflow-dev
B2_ACCESS_KEY_ID=minioadmin
B2_SECRET_ACCESS_KEY=minioadmin

# Comma-separated list of emails permitted to sign in. Empty disables the allowlist (dev only).
ALLOWED_EMAILS=

# Logging
LOG_LEVEL=debug
